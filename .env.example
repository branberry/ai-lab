# --- Provider API keys (optional; only needed for closed-model experiments) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Local Ollama ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Lab defaults ---
# Default model used for probes and technique experiments.
LAB_MODEL=ollama/qwen2.5:7b-instruct
# Stronger local model used as LLM-judge for evals.
LAB_JUDGE_MODEL=ollama/qwen2.5:14b-instruct

# Strip the "ollama/" prefix before sending to the Ollama API.
LAB_OLLAMA_PREFIX=ollama/
